# Coqui Web — Multi-stage Docker build
#
# Stage 1: Build Flutter web app with WASM
# Stage 2: Serve with nginx:alpine (~5MB runtime image)
#
# Build:  docker build -f Dockerfile.web -t coqui-web .
# Run:    docker run -p 8080:80 coqui-web

# ── Stage 1: Flutter Build ───────────────────────────────────────────────
FROM ghcr.io/cirruslabs/flutter:stable AS builder

WORKDIR /app

# Copy dependency files first for layer caching
COPY pubspec.yaml pubspec.lock ./
RUN flutter pub get

# Copy the rest of the source
COPY . .

# Build web with WASM for maximum performance
RUN flutter build web --wasm --release --base-href /

# ── Stage 2: Nginx Runtime ──────────────────────────────────────────────
FROM nginx:alpine

LABEL org.opencontainers.image.title="Coqui Web"
LABEL org.opencontainers.image.description="Coqui AI agent chat client — browser-based WASM build"
LABEL org.opencontainers.image.source="https://github.com/AgentCoqui/coqui-app"

# Remove default nginx config and content
RUN rm -rf /usr/share/nginx/html/* /etc/nginx/conf.d/default.conf

# Copy custom nginx config
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy Flutter web build output
COPY --from=builder /app/build/web /usr/share/nginx/html

# Ensure correct permissions
RUN chmod -R 755 /usr/share/nginx/html

EXPOSE 80

# Health check — verifies nginx is serving the app
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget -q --spider http://localhost/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
