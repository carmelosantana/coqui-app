<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>ai.coquibot.app</id>

  <name>Coqui</name>
  <summary>AI agent chat client</summary>

  <description>
    <p>
    Coqui is a cross-platform client for the Coqui AI agent. Connect to a Coqui API server, manage sessions, and chat with your agent in real-time via SSE streaming.
    </p>
    <p>
    Key Features:
    </p>
    <ul>
      <li>Connect to Coqui API servers</li>
      <li>Role-based session creation</li>
      <li>Real-time SSE message streaming</li>
      <li>Multiple server instance support</li>
      <li>Tool output rendering</li>
      <li>Session persistence</li>
    </ul>
  </description>

  <icon type="stock">ai.coquibot.app</icon>
  <launchable type="desktop-id">ai.coquibot.app.desktop</launchable>

  <developer id="ai.coquibot">
     <name>Coqui Bot</name>
  </developer>

  <categories>
    <category>Utility</category>
    <category>Development</category>
    <category>Chat</category>
  </categories>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-only</project_license>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>

  <content_rating type="oars-1.1" />

  <url type="homepage">https://agentcoqui.com</url>
  <url type="vcs-browser">https://github.com/AgentCoqui/coqui-app</url>
  <url type="bugtracker">https://github.com/AgentCoqui/coqui-app/issues</url>

