**/macos/Pods/
**/linux/flutter/ephemeral/
**/windows/flutter/ephemeral/

# Local icon-editing artifacts
assets/images/*.backup.png
assets/images/*.test.png

# Release signing artifacts (never commit)
android/key.properties
android/app/*.jks
*.jks
*.keystore
*.p12
